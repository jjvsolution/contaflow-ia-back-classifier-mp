DATABASE_URL=postgresql://postgres:postgres@localhost:5432/contaflow
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768
# Debe coincidir con LLM_INTERNAL_TOKEN del backend (M01-017)
INTERNAL_TOKEN=cambia-este-token-compartido
RAG_COMPANY_LIMIT=8
RAG_GIRO_LIMIT=8
# INFO en prod (sin dumps de documento). DEBUG muestra preview de input_text.
LOG_LEVEL=INFO
